    {
      "id": "6998c74984148b0007422fb9",
      "name": "Escalate to human support",
      "createdByID": 1953576,
      "folderID": null,
      "settings": {
        "model": "claude-4-sonnet",
        "maxTokens": 5000,
        "temperature": 0.3,
        "reasoningEffort": null
      },
      "description": null,
      "instructions": [
        {
          "text": [
            "Apologize for not being able to resolve the issue and summarize the conversation, including all collected details, then create a Zendesk support ticket for handoff. Inform the user that a human agent will follow up as soon as possible. Close the conversation professionally."
          ]
        }
      ],
