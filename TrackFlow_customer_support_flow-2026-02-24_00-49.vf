    {
      "id": "6998c74984148b0007422fb8",
      "name": "Confirm issue resolved",
      "createdByID": 1953576,
      "folderID": null,
      "settings": {
        "model": "claude-4-sonnet",
        "maxTokens": 5000,
        "temperature": 0.3,
        "reasoningEffort": null
      },
      "description": null,
      "instructions": [
        {
          "text": [
            "Confirm with the user that their issue is fully resolved. Offer a quick summary and thank them for choosing TrackFlow support. Politely close the conversation."
          ]
        }
      ],
      "pathToolOrder": [
        "6998c74984148b0007422fd4"
      ],
      "webSearchTool": null,
      "knowledgeBaseTool": null,
